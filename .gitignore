# AI Pokedex — Local files to ignore

# Python
__pycache__/
*.py[cod]
*$py.class
*.egg-info/
.eggs/
dist/
build/

# Virtual environment
.venv/
venv/
env/

# ChromaDB persistent stores (keep data, but don't commit to git)
chroma_pokemon_kb/
chroma_user_memory/

# SQLite caches
cache/*.db

# MLX model cache
.mlx_cache/

# OS
.DS_Store
Thumbs.db

# IDE
.vscode/
.idea/

# Logs
*.log
logs/
